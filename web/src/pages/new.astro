---

import AppLayout from '../layouts/AppLayout.astro';
import NewAnnotationPage from '../views/core/New';

const user = Astro.locals.user;
if (!user) {
	return Astro.redirect('/login');
}

const url = Astro.url.searchParams.get('url') || undefined;
const selector = Astro.url.searchParams.get('selector') || undefined;
const quote = Astro.url.searchParams.get('quote') || undefined;
---

<AppLayout title="New Annotation - Margin" user={user}>
	<NewAnnotationPage client:load initialUrl={url} initialSelectorJson={selector} initialQuote={quote} />
</AppLayout>
