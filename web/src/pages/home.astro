---

import AppLayout from '../layouts/AppLayout.astro';
import Feed from '../views/core/Feed';

const user = Astro.locals.user;
const tag = Astro.url.searchParams.get('tag') || undefined;
---

<AppLayout title="Home - Margin" user={user}>
	<Feed client:load initialType="all" initialTag={tag} initialUser={user} />
</AppLayout>
